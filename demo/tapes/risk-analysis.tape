# Risk analysis: dedicated risk view with grouped changes
resize 80 20
wait ready
sleep 300ms

# Open risk analysis
key R
wait ready
sleep 1.5s

# Scroll through risk groups
key down
sleep 300ms
key down
sleep 300ms
key down
sleep 300ms
key down
sleep 300ms
key down
sleep 500ms

# Expand a risk group
key enter
sleep 2s
