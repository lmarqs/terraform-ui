#!/usr/bin/env bash
#MISE description="Verify 100% test coverage. Run before opening a PR to catch untested code paths."

packages=$(go list ./... | grep -v '/cmd/' | grep -v 'internal/terraform/exec$')
go test -coverprofile=coverage.out $packages
total=$(go tool cover -func=coverage.out | grep '^total:' | awk '{print $3}' | tr -d '%')
echo "Coverage: ${total}%"
threshold=100
if awk "BEGIN {exit !($total < $threshold)}"; then
  echo "FAIL: ${total}% is below ${threshold}% threshold"
  exit 1
fi
